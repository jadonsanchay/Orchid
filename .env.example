# ==============================================================================
# Orchid Environment Variables Configuration Template
# Duplicate this file as '.env' and populate it with your active credentials.
# ==============================================================================

# Supabase / PostgreSQL Database Connection URL
# Format: postgresql://[USER]:[PASSWORD]@[HOST]:[PORT]/[DBNAME]
SUPABASE_DB_URL=postgresql://postgres:[YOUR_SUPABASE_PASSWORD]@db.[YOUR_SUPABASE_REF].supabase.co:5432/postgres

# AI Provider API Keys
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_google_gemini_api_key_here

# Integration Testing Database URL (optional, used for running pkg/repository tests)
# WARNING: Integration tests execute migrations and cleanups. Use a test database!
TEST_DATABASE_URL=postgresql://postgres:[YOUR_SUPABASE_PASSWORD]@db.[YOUR_SUPABASE_REF].supabase.co:5432/postgres
